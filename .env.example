# Sandra University — environment variables

# Production Supabase project: sandra-university (BMH Group org)
NEXT_PUBLIC_SUPABASE_URL=https://dhvfsyteqsxagokoerrx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRodmZzeXRlcXN4YWdva29lcnJ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY5NzY2MTIsImV4cCI6MjA5MjU1MjYxMn0.HzMJIZolBNHNnPKf-iUijXJ4b2gRtUypXaCP6YJVJtg

# Service role key — grab from Supabase Dashboard → Project Settings → API.
# DO NOT commit real values. Used only by edge functions, server actions, and admin-only RPCs.
SUPABASE_SERVICE_ROLE_KEY=replace_me

# App base URL (used in invite and notification emails)
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Transactional email via SendGrid (chosen to consolidate under Twilio).
# Create an API key at https://app.sendgrid.com/settings/api_keys with "Mail
# Send" permission. SENDGRID_FROM_EMAIL must match a Single Sender or an
# address inside a domain-authenticated zone.
SENDGRID_API_KEY=replace_me
SENDGRID_FROM_EMAIL=jarrad@bmhgroupkc.com
SENDGRID_FROM_NAME=Sandra University

# Admins — comma-separated list of emails that automatically get system_role='owner' or 'admin'.
# Defaults to jarrad@bmhgroup.com. Safe to leave blank during initial dev.
ADMIN_EMAILS=jarrad@bmhgroup.com

# --- Claude's prod verification harness (Playwright) ---
# Populate these in .env.test.local (never commit) so `npm run test:prod` can
# log into the live deployment and verify authenticated surfaces. Read-only
# specs only — this uses a real account against the production Supabase.
# E2E_PROD_BASE_URL=https://sandra-university.vercel.app
# E2E_TEST_EMAIL=your@email.com
# E2E_TEST_PASSWORD=your_password
